# Void.Store — Render Environment（複製為 void-store-render.env 後填入真實值）
# Render → Services → null0dv-void-store → Environment → Add from .env

# LINE 官方帳號詢價連結（必填其一，建議兩個都填）
# 取得方式：LINE Official Account Manager → 帳號設定 → 連結 → 複製「傳送訊息」連結
# 格式範例：https://line.me/R/oaMessage/@voidstore/
LINE_INQUIRY_URL=

# LINE 官方群組邀請連結（選填）
# 取得方式：群組 → 設定 → 邀請 → 複製邀請連結
# 格式範例：https://line.me/ti/g/xxxxxxxxxx
LINE_GROUP_URL=